# AWS Credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_DEFAULT_REGION=
# Optional: Required only when using temporary credentials (e.g. AWS SSO, STS AssumeRole)
# AWS_SESSION_TOKEN=

# Agent Runtime ARN from your AgentCore deployment.
# Don't edit this by hand; launch.sh fills it in automatically from .bedrock_agentcore.yaml.
AGENT_RUNTIME_ARN=

# The Daily room URL that users will join to talk to the agent.
DAILY_ROOM_URL=https://YOURDOMAIN.daily.co/YOURROOM
