DEEPGRAM_API_KEY=
CARTESIA_API_KEY=

# Daily room configuration.
# Only needed for local development (PIPECAT_LOCAL_DEV=1).
# When running on AgentCore, the room URL is passed via the server's trigger payload.
# DAILY_ROOM_URL=https://YOURDOMAIN.daily.co/YOURROOM
# DAILY_API_KEY=

# AWS credentials.
# Only needed for local development (PIPECAT_LOCAL_DEV=1).
# When running on AgentCore, credentials come from assumed IAM role.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
