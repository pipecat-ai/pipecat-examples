# Leave blank for local development (proxies to the local bot server).
# Set to your Pipecat Cloud agent URL to connect directly from the browser.
VITE_BOT_START_URL=https://api.pipecat.daily.co/v1/public/YOUR_AGENT_NAME/start

# Your Pipecat Cloud public API key (only needed when VITE_BOT_START_URL is set).
VITE_BOT_START_PUBLIC_API_KEY=your_pipecat_cloud_public_api_key
