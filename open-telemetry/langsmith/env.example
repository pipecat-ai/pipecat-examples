DEEPGRAM_API_KEY=your_deepgram_key
CARTESIA_API_KEY=your_cartesia_key
OPENAI_API_KEY=your_openai_key

# LangSmith tracing
LANGSMITH_API_KEY=your_langsmith_key
# Set to any value to enable tracing
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=pipecat-voice

# Set this when your LLM stage is an in-process LangGraph or LangChain agent so
# its runs nest inside Pipecat's llm span instead of forming a separate trace.
# LANGSMITH_TRACING_MODE=otel
